            self._create_heating_cycle(base_datetime - timedelta(days=i))
            for i in range(0, 365, 30)
        ]
        mock_heating_cycle_service.extract_heating_cycles.return_value = many_cycles

        # WHEN: update_cycles_for_window is called
        result = await manager.update_cycles_for_window(device_id, start_time, end_time)

        # THEN: All cycles are returned
        assert len(result) == len(many_cycles)


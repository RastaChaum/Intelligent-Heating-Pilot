    @pytest.mark.asyncio
    async def test_on_24h_timer_refreshes_cycles_and_updates_cache(
        self,
        manager: HeatingCycleLifecycleManager,
        mock_heating_cycle_service: Mock,
        mock_cycle_cache: Mock,
        mock_model_storage: Mock,
        base_datetime: datetime,
    ) -> None:
        """Test 24h timer refreshes cycles and updates memory cache.

        RED: Should fail - timer refresh incomplete.
        Expected: Timer triggers cycle refresh and cache update.
        """
        # GIVEN: Device config with retention days
        # Manager timestamp references
        new_cycles = [
            self._create_heating_cycle(base_datetime - timedelta(hours=2)),
            self._create_heating_cycle(base_datetime - timedelta(hours=1)),
        ]
        mock_heating_cycle_service.extract_heating_cycles.return_value = new_cycles

        # WHEN: 24h timer fires
        await manager.on_24h_timer()

        # THEN: Cycles and LHS were re-extracted and stored
        mock_heating_cycle_service.extract_heating_cycles.assert_called_once()
        mock_model_storage.set_heating_cycle.assert_called_once()
        mock_model_storage.set_cache_global_lhs.assert_called_once()
        mock_model_storage.set_cache_contextual_lhs.assert_called_once()

        # AND: Cache was updated with new cycles
        mock_cycle_cache.append_cycles.assert_called_once()

    # ===== Test: Event Integration - Complete Flow =====

    @pytest.mark.asyncio
    async def test_retention_change_flow_full_cycle(
        self,
        manager: HeatingCycleLifecycleManager,
        mock_cycle_cache: Mock,
        base_datetime: datetime,
    ) -> None:
        """Test complete flow: retention change invalidates cache and forces reload.

        RED: Should fail - complete retention change flow missing.
        Expected: Retention change → cache cleared → next access reloads from storage.
        """
        # GIVEN: Cycles cached for 30-day window
        device_id = "climate.test_vtherm"
        start_time = base_datetime - timedelta(days=30)
        target_time = base_datetime

        old_cycles = [
            self._create_heating_cycle(start_time),
            self._create_heating_cycle(start_time + timedelta(days=10)),
            self._create_heating_cycle(start_time + timedelta(days=20)),
        ]
        mock_cycle_cache.get_cache_data.return_value = Mock(cycles=old_cycles)

        # Load old cycles into memory
        old_result = await manager.get_cycles_for_target_time(device_id, target_time)
        assert len(old_result) == 3

        # Reset cache mock
        mock_cycle_cache.reset_mock()

        # WHEN: Retention changes from 30 to 14 days
        await manager.on_retention_change(14)

        # THEN: Cache was cleared
        # (May call clear_cache or similar)

        # AND: New retention window applied
        new_start = base_datetime - timedelta(days=14)
        new_cycles = [
            self._create_heating_cycle(new_start),
            self._create_heating_cycle(new_start + timedelta(days=7)),
        ]
        mock_cycle_cache.get_cache_data.return_value = Mock(cycles=new_cycles)

        # Get cycles with new retention window
        new_result = await manager.get_cycles_for_target_time(device_id, target_time)

        # THEN: Result reflects new window (different cycles or count)
        # (May be same or fewer depending on data)
        assert len(new_result) == 2

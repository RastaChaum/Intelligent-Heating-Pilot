    # ===== Test: Memory Caching - GET Methods =====

    @pytest.mark.asyncio
    async def test_get_cycles_for_target_time_memory_hit_no_extraction(
        self,
        manager: HeatingCycleLifecycleManager,
        mock_cycle_cache: Mock,
        base_datetime: datetime,
    ) -> None:
        """Test get_cycles_for_target_time uses memory cache to avoid re-extraction.

        RED: Should fail - no memory cache implementation.
        Expected: First call extracts cycles, second call for same day uses memory.
        """
        # GIVEN: Cycles already in memory for this date
        device_id = "climate.test_vtherm"
        target_time = base_datetime
        test_cycles = [self._create_heating_cycle(base_datetime)]
        mock_cycle_cache.get_cache_data.return_value = Mock(cycles=test_cycles)

        # WHEN: First call to get_cycles_for_target_time
        result1 = await manager.get_cycles_for_target_time(device_id, target_time)
        call_count_first = mock_cycle_cache.get_cache_data.call_count

        # WHEN: Second call for same target date
        result2 = await manager.get_cycles_for_target_time(device_id, target_time)
        call_count_second = mock_cycle_cache.get_cache_data.call_count

        # THEN: First call hit cache, second call maybe not (if memory cached)
        assert len(result1) > 0
        assert result1 == result2
        assert call_count_first == 1
        assert call_count_second == call_count_first

        # If memory cache works, cache calls should NOT increase significantly
        # (May be 1 or 2, but shouldn't spike with each call)

    @pytest.mark.asyncio
    async def test_get_cycles_for_window_returns_matching_window(
        self,
        manager: HeatingCycleLifecycleManager,
        mock_cycle_cache: Mock,
        base_datetime: datetime,
    ) -> None:
        """Test get_cycles_for_window properly filters cycles to time window.

        RED: Should fail - filtering logic incomplete.
        Expected: Returns only cycles within requested start/end times.
        """
        # GIVEN: Cycles both inside and outside time window
        device_id = "climate.test_vtherm"
        start_time = base_datetime
        end_time = base_datetime + timedelta(days=3)

        cycle_inside = self._create_heating_cycle(start_time + timedelta(hours=2))
        cycle_before = self._create_heating_cycle(start_time - timedelta(days=1))
        cycle_after = self._create_heating_cycle(end_time + timedelta(days=1))

        all_cycles = [cycle_before, cycle_inside, cycle_after]
        mock_cycle_cache.get_cache_data.return_value = Mock(cycles=all_cycles)

        # WHEN: get_cycles_for_window called for specific time range
        result = await manager.get_cycles_for_window(device_id, start_time, end_time)

        # THEN: Only cycles within window are returned
        assert len(result) == 1
        assert cycle_inside in result
        assert cycle_before not in result
        assert cycle_after not in result

    # ===== Test: Event Methods Update Storage AND Memory =====

    @pytest.mark.asyncio
    async def test_startup_extracts_cycles_and_caches_in_memory(
        self,
        manager: HeatingCycleLifecycleManager,
        mock_heating_cycle_service: Mock,
        mock_cycle_cache: Mock,
        base_datetime: datetime,
    ) -> None:
        """Test startup extracts cycles and populates memory cache.

        RED: Should fail - no memory cache population on startup.
        Expected: Startup extracts cycles and they're available in memory cache.
        """
        # GIVEN: Heating cycle service returns cycles
        device_id = "climate.test_vtherm"
        start_time = base_datetime - timedelta(days=30)
        end_time = base_datetime

        test_cycles = [
            self._create_heating_cycle(start_time),
            self._create_heating_cycle(start_time + timedelta(days=5)),
        ]
        mock_heating_cycle_service.extract_heating_cycles.return_value = test_cycles

        # WHEN: Startup is called
        result = await manager.startup(device_id, start_time, end_time)

        # THEN: Cycles were extracted
        assert len(result) == 2
        assert result == test_cycles

        # AND: Cycles are cached for quick retrieval
        # Subsequent get_cycles_for_target_time for this date should use cache
        mock_cycle_cache.reset_mock()
        target_in_window = start_time + timedelta(days=2)
        cached_result = await manager.get_cycles_for_target_time(device_id, target_in_window)

        # If memory cached properly, should get results without hitting adapters again
        assert len(cached_result) > 0

